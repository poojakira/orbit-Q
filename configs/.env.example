# Orbit-Q Configuration Template
# Copy this to .env and fill in your credentials

# --- Infrastructure ---
# Your Firebase Realtime Database URL
# Example: https://orbit-q-default-rtdb.firebaseio.com/
FIREBASE_DB_URL=

# Path to your Firebase service account JSON key
# Default: service_account.json
SERVICE_ACCOUNT_PATH=service_account.json

# --- Security ---
# Secret key for HMAC-SHA256 telemetry authentication
ORBIT_Q_SIGNING_SECRET=generate-a-secure-random-string-here

# --- ML Governance (MLflow) ---
# Where to store MLflow runs (SQLite local db by default)
MLFLOW_TRACKING_URI=sqlite:///mlflow.db
MLFLOW_EXPERIMENT_NAME=CubeSat_3D_Anomaly_Engine

# --- Model Storage ---
# Path to save/load the trained ensemble model
MODEL_PATH=models/orbit_q_ensemble_latest.pkl

# --- Hyperparameters ---
# Expected percentage of anomalies in the training data (0.05 = 5%)
CONTAMINATION=0.05
# Number of trees in the Isolation Forest
N_ESTIMATORS=200
# Window size for rolling features (SMA, StdDev)
ROLLING_WINDOW=5
